<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.amaal.ghads.controller.UserManagementController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <Label text="إدارة المنسقين والحسابات المعتمدة" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
                <TableView fx:id="tblUsers" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn prefWidth="100.0" text="رقم المستخدم" />
                        <TableColumn prefWidth="250.0" text="الاسم الكامل" />
                        <TableColumn prefWidth="200.0" text="اسم المستخدم" />
                        <TableColumn prefWidth="200.0" text="الدور المعين" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</AnchorPane>